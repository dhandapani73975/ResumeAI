# ==========================================================================
# ResumeAI - Environment Variables Configuration Template
# ==========================================================================

# Django Settings
SECRET_KEY=django-insecure-ai-resume-analyzer-key-2026-very-secret
DEBUG=True
ALLOWED_HOSTS=*,localhost,127.0.0.1

# Groq AI Service API Connection
# Obtain key at: https://console.groq.com/
# Leave empty to enable the premium High-Fidelity Mock Mode fallback!
GROQ_API_KEY=

# Database System Settings
# Default: sqlite3 (Runs out of the box with zero setup)
# For production or Docker configurations, set DB_ENGINE=postgresql
DB_ENGINE=sqlite3
DB_NAME=resume_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
